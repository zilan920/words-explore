# Non-secret runtime config lives in TypeScript:
# - src/lib/appConfig.ts: word batch size, frontend study queue target size, and auto-next countdown
# - src/lib/serverConfig.ts: LLM provider/model/base URL, dictionary lookup, and storage driver/path
#
# File storage config is here:
# src/lib/serverConfig.ts -> serverConfig.storage
#
# Example:
# storage: {
#   driver: "file",
#   sqlitePath: "data/words-explore.sqlite",
#   libsqlUrl: ""
# }

# LLM setup. Mock recommendations are used without a key.
# Provider names come from serverConfig.llm.providers, for example: deepseek, openai, volcengine.
# Provider-specific keys such as DEEPSEEK_API_KEY are still supported.
LLM_PROVIDER=deepseek
WORDS_EXPLORE_LLM_API_KEY=
# Optional. Overrides the active provider's TypeScript default. Valid range: 0-2.
LLM_TEMPERATURE=
# Optional. Overrides the active provider's TypeScript default. The default is 3.
LLM_WORDS_PER_REQUEST=

# libSQL/Turso auth token.
# Set serverConfig.storage.driver to "libsql" and libsqlUrl in src/lib/serverConfig.ts.
LIBSQL_AUTH_TOKEN=
