# Local development uses data/words-explore.sqlite automatically.
# Set these for Vercel + Turso/libSQL.
LIBSQL_URL=
LIBSQL_AUTH_TOKEN=

# Optional LLM provider. Mock recommendations are used without a key.
# DeepSeek is OpenAI-compatible. Use DEEPSEEK_API_KEY for normal setup.
LLM_PROVIDER=deepseek
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_THINKING=disabled
DEEPSEEK_TEMPERATURE=1.3
DEEPSEEK_TIMEOUT_MS=15000
# Optional. Leave empty to let DeepSeek use its default output limit.
DEEPSEEK_MAX_TOKENS=

# Generic OpenAI-compatible fallback. Leave empty when using the DeepSeek variables above.
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4.1-mini
LLM_THINKING=
LLM_TEMPERATURE=1.3
LLM_TIMEOUT_MS=15000
LLM_MAX_TOKENS=
