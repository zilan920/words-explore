# Non-secret runtime config lives in TypeScript:
# - src/lib/appConfig.ts: word batch size and auto-next countdown
# - src/lib/serverConfig.ts: LLM provider/model/base URL and storage driver/path
#
# File storage config is here:
# src/lib/serverConfig.ts -> serverConfig.storage
#
# Example:
# storage: {
#   driver: "file",
#   sqlitePath: "data/words-explore.sqlite",
#   libsqlUrl: ""
# }

# DeepSeek setup. Mock recommendations are used without a key.
DEEPSEEK_API_KEY=
# Optional. Overrides serverConfig.llm.deepseek.temperature. Valid range: 0-2.
DEEPSEEK_TEMPERATURE=

# Generic OpenAI-compatible provider key.
# Set serverConfig.llm.provider to "openai-compatible" before using this.
LLM_API_KEY=
# Optional. Used by the generic provider and as a DeepSeek fallback when DEEPSEEK_TEMPERATURE is unset.
# Valid range: 0-2.
LLM_TEMPERATURE=

# libSQL/Turso auth token.
# Set serverConfig.storage.driver to "libsql" and libsqlUrl in src/lib/serverConfig.ts.
LIBSQL_AUTH_TOKEN=
